# Buckler's Boot Camp (CAPCOM ID)
CAPCOM_EMAIL=your_capcom_email@example.com
CAPCOM_PASSWORD=your_capcom_password

# Mastodon
MASTODON_INSTANCE=https://your.mastodon.instance
MASTODON_ACCESS_TOKEN=your_mastodon_access_token

# Bluesky
BLUESKY_HANDLE=your.handle.bsky.social
BLUESKY_APP_PASSWORD=your_bluesky_app_password

# X/Twitter (OAuth 1.0a - all 4 required for posting)
TWITTER_CONSUMER_KEY=your_consumer_key
TWITTER_CONSUMER_SECRET=your_consumer_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
